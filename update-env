#!/usr/bin/env bash

# update-env -- create and maintain my work environment

# Naming Policy:
#
# All function and variable names are camelCased.
#
# Local variable names begin with lowercase letters, e.g. localVariable.
# Global variable names begin with uppercase letters, e.g. GlobalVariable.
#
# Variable declarations that are name references borrow the environment namespace, e.g.
# "local -n ARRAY=$1".
#
# Locally-defined task functions are suffixed with "Task".

# the persistent crostini directory
# it does not have spaces and is exempt from quoting
CrostiniDir=/mnt/chromeos/MyFiles/Downloads/crostini

# MAIN ORCHESTRATION FLOW
# -----------------------
#
#  ┌─────────────────────────────────────────────────────────────┐
#  │ PHASE 1: System & Credentials (section system)              │
#  │   ├─> [crostini/linux] apt upgrade                          │
#  │   └─> SSH key installation:                                 │
#  │       • np_id_ed25519 (non-passphrase) if exists            │
#  │       • id_ed25519 (unique) as fallback                     │
#  └─────────────────────────────────────────────────────────────┘
#                            ↓
#  ┌─────────────────────────────────────────────────────────────┐
#  │ PHASE 2: Dotfiles & Configuration (section dotfiles)        │
#  │   ├─> Clone dotfiles from GitHub                            │
#  │   └─> Create symlinks:                                      │
#  │       • bash configs → ~/.bashrc, ~/.profile                │
#  │       • git configs → ~/.gitconfig, ~/.gitignore_global     │
#  │       • tmux → ~/.tmux.conf                                 │
#  │       • liquidprompt theme                                  │
#  │       • SSH config and authorized_keys                      │
#  └─────────────────────────────────────────────────────────────┘
#                            ↓
#  ┌─────────────────────────────────────────────────────────────┐
#  │ PHASE 3: Package Management (sections nix & home-manager)   │
#  │   ├─> Install Nix (Lix installer)                           │
#  │   ├─> Fix /nix ownership                                    │
#  │   ├─> Add Home Manager channel                              │
#  │   └─> Apply Home Manager configuration                      │
#  └─────────────────────────────────────────────────────────────┘
#                            ↓
#  ┌─────────────────────────────────────────────────────────────┐
#  │ PHASE 4: Platform-Specific Setup                            │
#  │   └─> [crostini only]:                                      │
#  │       • Link ~/crostini → $CrostiniDir                      │
#  │       • Clone project directories from permanent mount      │
#  └─────────────────────────────────────────────────────────────┘
#                            ↓
#  ┌─────────────────────────────────────────────────────────────┐
#  │ PHASE 5: Development Tools (various sections)               │
#  │   ├─> fp.bash    - functional programming utilities         │
#  │   ├─> mk.bash    - build tool & git updater                 │
#  │   ├─> task.bash  - task automation (this script!)           │
#  │   └─> tesht      - testing framework                        │
#  │       All cloned from GitHub and symlinked to ~/.local/bin  │
#  └─────────────────────────────────────────────────────────────┘
#                            ↓
#  ┌─────────────────────────────────────────────────────────────┐
#  │ PHASE 6: Applications & VPN (section apps & various)        │
#  │   ├─> [crostini/linux] GlobalProtect VPN client             │
#  │   ├─> Neovim setup (vim-plug, plugins)                      │
#  │   ├─> Daily notes repository                                │
#  │   └─> Ranger file manager configs                           │
#  └─────────────────────────────────────────────────────────────┘
#                            ↓
#  ┌─────────────────────────────────────────────────────────────┐
#  │ PHASE 7: SSH Key Generation (section unique_credential)     │
#  │   └─> [crostini/linux] Generate unique SSH key if needed    │
#  │       • Remove non-passphrase key if it was copied          │
#  │       • Generate new passphrase-protected key               │
#  └─────────────────────────────────────────────────────────────┘
#                            ↓
#  ┌─────────────────────────────────────────────────────────────┐
#  │ FINALIZATION                                                │
#  │   └─> Display task summary                                  │
#  └─────────────────────────────────────────────────────────────┘
#
main() {
  set -euo pipefail   # enable strict mode

  #  ┌─────────────────────────────────────────────────────────────┐
  #  │ PHASE 1: System & Credentials (section system)              │
  #  │   ├─> [crostini/linux] apt upgrade                          │
  #  │   └─> SSH key installation:                                 │
  #  │       • np_id_ed25519 (non-passphrase) if exists            │
  #  │       • id_ed25519 (unique) as fallback                     │
  #  └─────────────────────────────────────────────────────────────┘
  section system
  each task.Ln <<'  END'
    .config         ~/config
    .local          ~/local
    .ssh            ~/ssh
    secrets/netrc   ~/.netrc
  END
  platform=$(platform)
  case $platform in crostini|debian )
    aptUpgradeTask
  ;; esac

  case $platform in crostini )
    local keyDir=$CrostiniDir
    if [[ -e $keyDir/np_id_ed25519.pub ]]; then
      section credential
      task.Install 600 $keyDir/np_id_ed25519 ~/.ssh/id_ed25519
      task.Install 644 $keyDir/np_id_ed25519.pub ~/.ssh/id_ed25519.pub
    elif [[ -e $keyDir/id_ed25519.pub ]]; then
      section credential
      task.Install 600 $keyDir/id_ed25519 ~/.ssh/id_ed25519
      task.Install 644 $keyDir/id_ed25519.pub ~/.ssh/id_ed25519.pub
    fi

    task.Ln $CrostiniDir/repos ~/repos
    task.Ln $CrostiniDir/secrets ~/secrets
    ;;
  esac

  #  ┌─────────────────────────────────────────────────────────────┐
  #  │ PHASE 2: Dotfiles & Configuration (section dotfiles)        │
  #  │   ├─> Clone dotfiles from GitHub                            │
  #  │   └─> Create symlinks                                       │
  #  └─────────────────────────────────────────────────────────────┘
  section dotfiles
  task.GitClone git@github.com:binaryphile/dotfiles ~/dotfiles main
  try task.GitUpdate ~/dotfiles
  each task.Ln <<'  END'
    contexts/"$platform"                          ~/dotfiles/context
    ~/dotfiles/bash/init.bash                     ~/.bash_profile
    ~/dotfiles/bash/init.bash                     ~/.bashrc
    ~/dotfiles/bash/init.bash                     ~/.profile
    ~/dotfiles/gitconfig                          ~/.gitconfig
    ~/dotfiles/gitignore_global                   ~/.gitignore_global
    ~/dotfiles/liquidprompt/liquid.theme          ~/.config/liquidprompt/liquid.theme
    ~/dotfiles/liquidprompt/liquidpromptrc        ~/.config/liquidpromptrc
    ~/dotfiles/ssh/authorized_keys                 ~/.ssh/authorized_keys
    ~/dotfiles/ssh/config                         ~/.ssh/config
    ~/dotfiles/tmux.conf                          ~/.tmux.conf
  END

  #  ┌─────────────────────────────────────────────────────────────┐
  #  │ PHASE 3: Package Management (sections nix & home-manager)   │
  #  │   ├─> Install Nix (Lix installer)                           │
  #  │   ├─> Fix /nix ownership                                    │
  #  │   ├─> Add Home Manager channel                              │
  #  │   └─> Apply Home Manager configuration                      │
  #  └─────────────────────────────────────────────────────────────┘

  case $platform in crostini|debian|linux|macos )
    section nix
    curlPipeLixInstallerTask
    chownRTask /nix "$(id -u)" "$(id -g)"
    loosely source /nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh
    task.Ln ~/dotfiles/config.nix ~/.config/nixpkgs/config.nix

    section home-manager
    nixChannelAddHomeManagerTask
    nixChannelUpdateTask
    nixShellHomeManagerInstallTask
    loosely source ~/.nix-profile/etc/profile.d/hm-session-vars.sh
    task.Ln ~/dotfiles/home.nix ~/.config/home-manager/home.nix
    homeManagerSwitchTask
    ;;
  esac

  #  ┌─────────────────────────────────────────────────────────────┐
  #  │ PHASE 4: Platform-Specific Setup                            │
  #  │   └─> [crostini only]:                                      │
  #  │       • Link ~/crostini → $CrostiniDir                      │
  #  │       • Clone project directories from permanent mount      │
  #  └─────────────────────────────────────────────────────────────┘
  if [[ $platform == crostini ]]; then
    section crostini
    task.Ln $CrostiniDir ~/crostini

    # clone from persisted repo directories to home dir
    local -A branches=(
      [tlilley-daily-notes.git]=main
      [urma-next-local.git]=main
    )
    (cd $CrostiniDir/repos; glob * | keepIf isDir) |
      map target '$CrostiniDir/repos/$target ~/projects/${target%.git} ${branches[$target]:-develop}' |
      each task.GitClone
  fi

  #  ┌─────────────────────────────────────────────────────────────┐
  #  │ PHASE 5: Development Tools (various sections)               │
  #  │   ├─> fp.bash    - functional programming utilities         │
  #  │   ├─> mk.bash    - build tool & git updater                 │
  #  │   ├─> task.bash  - task automation (this script!)           │
  #  │   ├─> tesht      - testing framework                        │
  #  │   └─> era        - semantic memory MCP server for AI agents │
  #  │       All cloned from GitHub and symlinked to ~/.local/bin  │
  #  └─────────────────────────────────────────────────────────────┘

  section fp.bash
  githubCloneAndLinkTask fp.bash develop
  task.Ln ~/projects/fp.bash/fp.bash ~/.local/lib/fp.bash

  section mk.bash
  githubCloneAndLinkTask mk.bash develop
  task.Ln ~/projects/mk.bash/mk.bash ~/.local/lib/mk.bash
  task.Ln ~/projects/mk.bash/mk-example ~/.local/bin/mk

  section task.bash
  githubCloneAndLinkTask task.bash main
  task.Ln ~/projects/task.bash/update-env  ~/.local/bin/update-env

  section tesht
  githubCloneAndLinkTask tesht develop
  task.Ln ~/projects/tesht/tesht ~/.local/bin/tesht

  section era
  codebergCloneAndLinkTask era main
  eraBuildTask
  each task.Ln <<'  END'
    ~/projects/era/era       ~/.local/bin/era
    ~/projects/era/era-mcp   ~/.local/bin/era-mcp
    ~/projects/era/era-hook  ~/.local/bin/era-hook
  END
  task.Install 644 ~/projects/era/era-mcp.service ~/.config/systemd/user/era-mcp.service
  eraSystemdEnableTask

  #  ┌─────────────────────────────────────────────────────────────┐
  #  │ PHASE 5b: Work Projects (VPN-dependent, graceful failure)   │
  #  │   ├─> urma-next     - main application                     │
  #  │   ├─> pepin         - build/deploy tooling                  │
  #  │   ├─> cloud-services                                        │
  #  │   └─> accelerated-linux                                     │
  #  │       All from stash.digi.com, require VPN                  │
  #  └─────────────────────────────────────────────────────────────┘

  section stash
  each 'try stashCloneAndLinkTask' <<'  END'
    urma-next develop urma
    pepin develop
    cloud-services develop
    accelerated-linux master accelerated-linux acl
    share main share ~tlilley
  END
  try writeMcpJsonTask ~/projects/urma

  #  ┌─────────────────────────────────────────────────────────────┐
  #  │ PHASE 6: Applications & VPN                                 │
  #  │   ├─> [crostini/linux] GlobalProtect VPN client             │
  #  │   ├─> Neovim setup (vim-plug, plugins)                      │
  #  │   ├─> Daily notes repository                                │
  #  │   └─> Ranger file manager configs                           │
  #  └─────────────────────────────────────────────────────────────┘

  section VPN client
  task.Ln ~/dotfiles/scripts/vpn-connect ~/.local/bin/vpn-connect

  section neovim
  task.GitClone git@github.com:binaryphile/dot_vim ~/.config/nvim master
  try task.GitUpdate ~/.config/nvim
  curlTask https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim ~/.local/share/nvim/site/autoload/plug.vim
  nvimHeadlessPlugInstallTask
  task.Ln ~/.config/nvim ~/nvim

  section obsidian
  try bitbucketCloneAndLinkTask tlilley-daily-notes main

  section ranger
  glob ~/dotfiles/ranger/* |
    keepIf isFile |
    map path '$path ~/.config/ranger/$(basename $path)' |
    each task.Ln

  section transcript-generator
  try task.Ln ~/projects/share/claude-transcript-generator/bin/transcript-generator ~/.local/bin/transcript-generator

  #  ┌─────────────────────────────────────────────────────────────┐
  #  │ PHASE 7: SSH Key Generation (section unique_credential)     │
  #  │   └─> [crostini/linux] Generate unique SSH key if needed    │
  #  │       • Remove non-passphrase key if it was copied          │
  #  │       • Generate new passphrase-protected key               │
  #  └─────────────────────────────────────────────────────────────┘
  case $platform in crostini )
    section unique_credential
    if [[ -e $keyDir/np_id_ed25519.pub ]]; then
      removeMatchingFileTask ~/.ssh/id_ed25519.pub $keyDir/np_id_ed25519.pub
      removeMatchingFileTask ~/.ssh/id_ed25519 $keyDir/np_id_ed25519
      rm $keyDir/np_id_ed25519{,.pub}
    fi
    sshKeygenTask $keyDir/id_ed25519
    task.Install 600 $keyDir/id_ed25519 ~/.ssh/id_ed25519
    task.Install 644 $keyDir/id_ed25519.pub ~/.ssh/id_ed25519.pub
    ;;
  esac

  #  ┌─────────────────────────────────────────────────────────────┐
  #  │ FINALIZATION                                                │
  #  │   ├─> Display task summary                                  │
  #  │   └─> Run deferred git updates (if mk was just installed)   │
  #  └─────────────────────────────────────────────────────────────┘
  task.Summarize
}

## task definitions

# system

# aptUpgradeTask upgrades all apt packages to latest.
# It first does an apt update.
aptUpgradeTask() {
  desc   'apt upgrade'
  prog   on
  runas  root
  unchg  '0 upgraded, 0 newly installed'

  cmd 'apt update -qq && apt upgrade -y'
}

bitbucketCloneAndLinkTask() {
  local repo=$1 branch=$2
  task.GitClone git@bitbucket.org:accelecon/$repo ~/projects/$repo $branch
  try task.GitUpdate ~/projects/$repo
}

codebergCloneAndLinkTask() {
  local repo=$1 branch=$2
  task.GitClone git@codeberg.org:binaryphile/$repo ~/projects/$repo $branch
  try task.GitUpdate ~/projects/$repo
}

eraBuildTask() {
  desc  'build era binaries'
  prog  on
  exist ~/projects/era/era-mcp

  cmd 'nix develop ~/projects/era --command bash -c "cd ~/projects/era && go generate ./internal/hugot/ && go build ./cmd/era/ && go build ./cmd/era-mcp/ && go build ./cmd/era-hook/"'
}

eraSystemdEnableTask() {
  desc  'enable era-mcp systemd service'
  ok    'systemctl --user is-enabled era-mcp &>/dev/null'
  cmd   'systemctl --user enable --now era-mcp'
}

writeMcpJsonTask() {
  local dir=$1
  desc   "write .mcp.json to $dir"
  exist  "$dir/.mcp.json"
  check  "[[ -d '$dir' ]]"

  writeMcpJson() {
    cat >"$dir/.mcp.json" <<'EOF'
{
  "mcpServers": {
    "atlassian": {
      "type": "stdio",
      "command": "uvx",
      "args": ["mcp-atlassian-with-bitbucket"],
      "env": {
        "BITBUCKET_URL": "https://stash.digi.com",
        "BITBUCKET_USERNAME": "${BITBUCKET_USERNAME}",
        "BITBUCKET_PERSONAL_TOKEN": "${BITBUCKET_TOKEN}"
      }
    }
  }
}
EOF
  }
  cmd writeMcpJson
}

stashCloneAndLinkTask() {
  local repo=$1 branch=$2 dir=${3:-$1} project=${4:-idigi}

  desc   "clone repo stash.digi.com/$project/$repo to ~/projects/$dir"
  exist  "$HOME/projects/$dir"
  check  'ping -c 1 -W 2 stash.digi.com'

  stashClone() {
    GIT_SSH_COMMAND='ssh -o StrictHostKeyChecking=no' git clone --branch "$branch" "git@stash.digi.com:$project/$repo.git" ~/projects/"$dir"
  }
  cmd stashClone

  try task.GitUpdate ~/projects/$dir
}

githubCloneAndLinkTask() {
  local repo=$1 branch=$2
  task.GitClone git@github.com:binaryphile/$repo ~/projects/$repo $branch
  try task.GitUpdate ~/projects/$repo
}

installGlobalProtectClient() {
  local dir
  dir=$(mktemp -d)
  trap "rm -rf $dir" EXIT
  curl -fsSL https://github.com/yuezk/GlobalProtect-openconnect/releases/download/v2.4.4/globalprotect-openconnect_2.4.4-1_amd64.deb >$dir/globalprotect-openconnect_2.4.4-1_amd64.deb
  sudo apt install -y --fix-broken $dir/globalprotect-openconnect_*.deb
}

installGlobalProtectClientTask() {
  desc  'install the GlobalProtect VPN client'
  exist /usr/bin/gpclient
  prog  on

  cmd installGlobalProtectClient
}

# nix

curlPipeLixInstallerTask() {
  desc   'install single-user nix'
  exist  /nix/var/nix/profiles/default/bin/nix-env
  prog   on

  cmd    'curl -sSf -L https://install.lix.systems/lix | sh -s -- install linux --no-confirm --init none'
}

# chownRTask recursively chowns $path with $user:$group.
# $user and $group are the numbered versions, e.g. 1000:1000, not username:groupname.
chownRTask() {
  local path=$1 user=$2 group=$3

  desc    "recursively change ownership of $path to $user:$group"
  runas   root

  ifIsOwnerAndGroup() { [[ $(ownerAndGroup $path) == "$user:$group" ]]; }
  ok ifIsOwnerAndGroup

  cmd "chown -R -- $user:$group $path"
}

# home manager

nixChannelAddHomeManagerTask() {
  desc   'add home manager channel'
  exist  ~/.nix-channels

  cmd    'nix-channel --add https://github.com/nix-community/home-manager/archive/master.tar.gz home-manager'
}

nixChannelUpdateTask() {
  desc   'update nix channels'
  prog   on
  exist  ~/.nix-defexpr/channels/home-manager

  cmd    'nix-channel --update'
}

nixShellHomeManagerInstallTask() {
  desc   'install home manager'
  prog   on
  exist  ~/.config/home-manager

  cmd    "nix-shell '<home-manager>' -A install"
}

homeManagerSwitchTask() {
  desc  'apply home manager configuration'
  prog  on
  unchg 'No change so reusing latest profile generation'

  cmd   'home-manager switch'
}

# neovim

curlTask() {
  local url=$1 filename=$2
  desc   "download ${url##*/} from ${url%/*} as $(basename $filename)"
  exist  $filename

  curlfsSL() {
    mkdir -p -- "$(dirname "$filename")"
    curl -fsSL -- "$url" >"$filename"
  }
  cmd curlfsSL
}

nvimHeadlessPlugInstallTask() {
  desc  'install neovim plugins'
  exist ~/.local/share/nvim/plugged

  cmd   'nvim --headless +PlugInstall +qall'
}

# credential

removeMatchingFileTask() {
  local targetFilename=$1 matchFilename=$2
  desc  "remove file $targetFilename if it matches $matchFilename"

  ifFilesDontMatch() {
    [[ -e $matchFilename ]] && ! [[ -e $targetFilename ]] ||
      [[ $(<$targetFilename) != $(<$matchFilename) ]]
  }
  ok ifFilesDontMatch

  rmTargetIfMatches() {
    if [[ -e $matchFilename && -e $targetFilename ]] &&
      [[ $(<$targetFilename) == $(<$matchFilename) ]];
    then
      rm $targetFilename
    fi
  }
  cmd rmTargetIfMatches
}

sshKeygenTask() {
  local keyFilename=$1
  desc  'generate an ssh key'
  exist $keyFilename
  prog  on

  generateKey() {
    local passphrase passphrase2
    read -sp 'generating ssh key.  passphrase: ' passphrase
    read -sp "${NL}again: " passphrase2
    [[ $passphrase == $passphrase2 ]] || { echo "${NL}passphrase did not match"; exit 1; }
    echo
    ssh-keygen -t ed25519 -f "$keyFilename" -N "$passphrase" -C "$USER@$(host)"
    cat "$keyFilename.pub"
  }
  cmd generateKey
}

## helpers

fatal() {
  local msg=$1 rc=${2:-$?}
  echo "fatal: $msg"
  exit $rc
}

glob() {
  local nullglobWasOn=0 noglobWasOn=1
  [[ $(shopt nullglob) == *on ]] && nullglobWasOn=1 || shopt -s nullglob  # enable nullglob
  [[ $- != *f* ]] && noglobWasOn=0 || set +o noglob                       # disable noglob

  eval "local results=( $* )"

  # reset to old settings
  (( noglobWasOn )) && set -o noglob
  (( nullglobWasOn )) || shopt -u nullglob

  local IFS=$NL
  (( ${#results[*]} == 0 )) || echo "${results[*]}"
}

host() {
  [[ $HOSTNAME == penguin && -e $CrostiniDir/hostname ]] && cat $CrostiniDir/hostname
  echo $HOSTNAME
}

isDir() { [[ -d "$1" ]]; }

isFile() { [[ -f "$1" ]]; }

loosely() {
  set +euo pipefail
  "$@"
  set -euo pipefail
}

ownerAndGroup() {
  local path=$1
  [[ $OSTYPE == darwin* && $(type -p stat) == /usr/bin/stat ]] && local flag=f || local flag=c
  echo $(stat -$flag %u $path):$(stat -$flag %g $path)
}

platform() {
  [[ $OSTYPE != darwin* ]] || { echo macos; return; }
  [[ $HOSTNAME != penguin ]] || { echo crostini; return; }
  ! [[ -e /etc/NIXOS ]] || { echo nixos; return; }
  ! [[ -e /etc/debian_version ]] || { echo debian; return; }
  echo linux
}


## fp

# each applies its arguments as a command to each argument from stdin.
each() {
  local command=$1 arg
  while IFS='' read -r arg; do
    eval "$command $arg"
  done
}

# keepIf filters lines from stdin using command.
keepIf() {
  local command=$1 arg
  while IFS='' read -r arg; do
    eval "$command $arg" && echo "$arg"
  done
  return 0
}

# map returns $EXPRESSION evaluated with the value of stdin as $VARNAME.
# $EXPRESSION must respect double-quoting rules and so can't contain naked quotes.
# $VARNAME may not be "VARNAME" or "EXPRESSION".
map() {
  local VARNAME=$1 EXPRESSION=$2
  case $VARNAME in VARNAME|EXPRESSION ) fatal "map: VARNAME may not be 'VARNAME' or 'EXPRESSION'";; esac
  local "$VARNAME"
  while IFS='' read -r "$VARNAME"; do
    eval "echo \"$EXPRESSION\""
  done
}

## globals

NL=$'\n'

## boilerplate

Here=$(cd "$(dirname "$BASH_SOURCE")"; cd -P "$(dirname "$(readlink "$BASH_SOURCE" || echo .)")"; pwd)
if [[ -e "$Here"/task.bash ]]; then
  source "$Here"/task.bash
else
  Lib=$(curl -fsSL https://raw.githubusercontent.com/binaryphile/task.bash/develop/task.bash) || exit
  eval "$Lib"
fi
unset -v Here Lib

return 2>/dev/null  # stop here if sourced, for interactive debugging

IsShortRun=0

# parse options
while [[ ${1:-} == -?* ]]; do
  case $1 in
    -h|--help   ) [[ -v Usage_ ]] && echo "$Usage_"; exit;;
    -x|--trace  ) set -x;;

    -s|--short )
      task.SetShortRun on
      IsShortRun=1
      ;;

    -- ) shift; break;;
  esac
  shift
done

main
